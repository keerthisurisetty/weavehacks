# Copy to .env and fill in. Never commit .env.

# Weights & Biases — Weave tracing + evals. Also the bearer token for the W&B MCP server.
# Get from https://wandb.ai/authorize ; then run `wandb login`.
WANDB_API_KEY=

# OpenAI — speaker, detectors, adjudicator, embeddings.
OPENAI_API_KEY=

# Model string. MUST support structured outputs (.beta.chat.completions.parse).
# Confirm a current model at the event; gpt-4o-2024-08-06 is a known-good structured-output model.
# (W&B Inference is an OpenAI-compatible alternative — see .claude/skills/weave.)
OPENAI_MODEL=gpt-4o-2024-08-06

# Redis Stack connection (pub/sub + RedisVL vector search + sorted sets).
REDIS_URL=redis://localhost:6379

# Weave project name passed to weave.init().
WEAVE_PROJECT=tell
